# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
# Cargo target dirs split by triple to avoid lock contention.
# `target/` is kept ignored as a safety net for any cargo invocation whose
# CWD doesn't resolve `.cargo/config.toml` — drop once we've confirmed there
# are no such call sites.
target-native/
target-wasm/
target/
dist/
build/
.next/
pkg/
/artifacts/
*.wasm
*.node
*.tsbuildinfo

# Stale tsc composite outputs that land alongside source when `tsc -b` is
# invoked from a referencing project. The real build (tsup) emits to dist/.
kernel/src/**/*.d.ts
kernel/src/**/*.d.ts.map
kernel/src/**/*.js
kernel/src/**/*.js.map

# Testing
coverage/

# IDE
.DS_Store
*.pem
.idea/
.vscode/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
.venv/
__pycache__/
*.pyc
*.so
*.dylib
*.pyd
*.whl
*.dSYM/

# Environment
.env*
!.env.example

# Misc
.mcp.json
!plugins/mog/.mcp.json
!plugins/mog/dist/
!plugins/mog/dist/**
# The Codex plugin browser bundle is generated by integrations/codex build.
plugins/mog/dist/browser/assets/browser.js
plugins/mog/dist/**/*.wasm
plugins/mog/dist/**/*.ttf
plugins/mog/dist/**/*.otf
plugins/mog/dist/**/*.woff
plugins/mog/dist/**/*.woff2
logo/generated/
rust_out
.wrangler/

# wasm-pack bootstrap lockfile
.wasm-pack.lock

# Local verdaccio / npm registry dev artifacts
scripts/htpasswd
scripts/verdaccio-htpasswd
scripts/verdaccio-storage/
*.bak
.dev-link-state.json
