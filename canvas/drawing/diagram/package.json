{
  "name": "@mog/diagram-engine",
  "version": "0.1.0",
  "license": "MIT",
  "files": [
    "src"
  ],
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./defaults": {
      "development": "./src/defaults/diagram-defaults.ts",
      "types": "./dist/defaults/diagram-defaults.d.ts",
      "import": "./dist/defaults/diagram-defaults.js"
    },
    "./engine": {
      "development": "./src/engine/index.ts",
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    },
    "./ooxml-engine-runtime": {
      "development": "./src/ooxml-engine-runtime.ts",
      "types": "./dist/ooxml-engine-runtime.d.ts",
      "import": "./dist/ooxml-engine-runtime.js"
    },
    "./parser": {
      "development": "./src/parser/index.ts",
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./types": {
      "development": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@mog/canvas-engine": "workspace:*",
    "@mog/drawing-engine": "workspace:*",
    "@mog/geometry": "workspace:*",
    "@mog/shape-engine": "workspace:*",
    "@mog-sdk/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.0"
  }
}
