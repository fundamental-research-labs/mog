{
  "name": "@mog/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mog": "./dist/mog.cjs"
  },
  "scripts": {
    "build": "pnpm --filter @mog-sdk/node build && tsup",
