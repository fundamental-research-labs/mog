{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "noEmit": true,
    "useDefineForClassFields": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@mog/devtools": ["../../tools/devtools/src/index.ts"],
      "@mog/devtools/console/api": ["../../tools/devtools/src/console/api.ts"],
      "@mog/devtools/invariants-slot": ["../../tools/devtools/src/invariants-slot.ts"],
      "@mog/devtools/shell-persistence": ["../../tools/devtools/src/shell-persistence.ts"],
      "@mog/devtools/ui/devtools-app": ["../../tools/devtools/src/ui/devtools-app.tsx"],
      "@mog-sdk/kernel/app-api": ["../../kernel/src/api/app/index.ts"]
    }
  },
  "include": ["src/**/*", "../../kernel/src/global.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
