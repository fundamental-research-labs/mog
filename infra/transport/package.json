{
  "name": "@mog/transport",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "development": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "development": "./src/index.browser.ts",
      "types": "./dist/index.browser.d.ts",
      "import": "./dist/index.browser.js"
    },
    "./napi": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wasm": {
      "development": "./src/index.wasm.ts",
      "types": "./dist/index.wasm.d.ts",
      "import": "./dist/index.wasm.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rust-bridge/client": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "@mog-sdk/wasm": "workspace:*"
  },
  "optionalDependencies": {
    "@mog/compute-core-napi": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1"
  }
}
