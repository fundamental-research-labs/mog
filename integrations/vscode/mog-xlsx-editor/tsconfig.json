{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["node", "vscode", "mocha"]
  },
  "include": ["src/**/*.ts", "webview/**/*.ts", "tests/**/*.ts", "scripts/**/*.mjs"]
}
