{
  "name": "@mog/spreadsheet",
  "version": "0.1.0",
  "private": true,
  "description": "Spreadsheet engine workspace",
  "scripts": {
    "typecheck": "node infra/icons/scripts/ensure-generated.mjs && tsc -b; code=$?; pnpm --filter @mog-sdk/contracts build; exit $code",
    "test": "pnpm -r --if-present --filter './apps/spreadsheet' --filter './canvas/drawing-canvas' --filter './canvas/drawing/engine' --filter './canvas/drawing/geometry' --filter './canvas/drawing/ink' --filter './canvas/drawing/shapes' --filter './canvas/drawing/diagram' --filter './canvas/drawing/text-effects' --filter './canvas/engine' --filter './canvas/grid-canvas' --filter './canvas/grid-renderer' --filter './canvas/overlay' --filter './charts' --filter './contracts' --filter './kernel' --filter './shell' --filter './table-engine' --filter './typeset/math-engine' run test",
    "build": "pnpm -r --if-present --filter './charts' --filter './connections' --filter './contracts' --filter './file-io' --filter './print-export' --filter './server' --filter './engine' --filter './testing' --filter './diagram' --filter './table-engine' run build",
    "build:bundle": "pnpm --filter @mog/transport --filter @mog/icons --filter @mog/app-spreadsheet run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm lint:boundaries",
    "check:ci:format": "pnpm format:check",
    "check:ci:lint": "pnpm lint",
    "check:ci:typecheck": "pnpm typecheck",
    "check:ci:public-boundaries": "pnpm validate:packages && pnpm lint:boundaries && pnpm check:platform-dependencies && pnpm check-cycles && pnpm check:host-surface-disposition",
    "check:publish-readiness": "pnpm check:ci:format && pnpm check:ci:public-boundaries && pnpm build:public-artifacts && pnpm check:release-readiness-naming && pnpm check:binary-wrapper-surfaces && pnpm check:contracts-declaration-identity && pnpm check:declaration-rollups && pnpm check:api-snapshots && pnpm check:external-fixtures -- --skip-build",
    "check:publish-readiness:fast": "pnpm check:ci:public-boundaries && pnpm check:release-readiness-naming",
    "check:publish-readiness:public": "pnpm check:ci:public-boundaries",
    "check:publish-readiness:sdk": "pnpm check:declaration-rollups && pnpm check:api-snapshots && pnpm check:external-fixtures -- --skip-build",
    "inventory:contracts": "node tools/contracts-shim-inventory.mjs",
    "check-cycles": "madge --circular --extensions ts --exclude '(dist|\\.claude/worktrees)' .",
    "generate:api-ref": "tsx tools/generate-api-reference.ts",
    "generate:bridge": "cargo test -p bridge-ts --test generate_handler_registry -- generate --nocapture && cargo test -p bridge-ts --test generate_compute_bridge -- --nocapture",
    "verify:xlsx-spec": "tsx ooxml/spec/tools/verify-contracts.ts",
    "true-coverage": "tsx ooxml/spec/tools/true-coverage.ts",
    "diag": "pnpm --filter @mog-sdk/kernel diag",
    "validate:packages": "node tools/validate-packages.mjs",
    "lint:boundaries": "eslint --no-inline-config --rule 'mog/import-boundaries: error' --ext .ts,.tsx apps/ canvas/ charts/ contracts/ file-io/ infra/ kernel/ runtime/ shell/ spreadsheet-utils/ table-engine/ types/ typeset/ ui/ views/",
    "build:public-artifacts": "node tools/build-public-artifacts.mjs",
    "assemble:public-packages": "node tools/assemble-public-packages.mjs",
    "check:public-package-manifests": "node fixtures/external/orchestrate.mjs --skip-build --manifest-only",
    "check:declaration-rollups": "node tools/check-declaration-rollups.mjs",
    "check:contract-identity": "node tools/check-contract-identity.mjs",
    "check:contracts-declaration-identity": "node tools/check-contracts-declaration-identity.mjs",
    "check:contracts-runtime-inventory": "node tools/check-contracts-runtime-inventory.mjs",
    "check:contract-runtime-imports": "node tools/check-contract-runtime-imports.mjs",
    "check:api-snapshots": "node tools/check-api-snapshots.mjs",
    "check:binary-wrapper-surfaces": "node tools/check-binary-wrapper-surfaces.mjs",
    "update:binary-wrapper-surfaces": "node tools/check-binary-wrapper-surfaces.mjs --update",
    "check:external-fixtures": "node fixtures/external/orchestrate.mjs",
    "check:host-surface-disposition": "node tools/check-host-surface-disposition.mjs",
    "check:platform-dependencies": "node tools/check-platform-dependencies.mjs",
    "check:release-readiness-naming": "node tools/release-readiness-scanner.mjs",
    "inventory:sdk-contract-graph": "node tools/inventory-sdk-contract-graph.mjs",
    "validate:all-boundaries": "pnpm check:ci:public-boundaries && pnpm build:public-artifacts && pnpm check:release-readiness-naming && pnpm check:binary-wrapper-surfaces && pnpm check:contracts-declaration-identity && pnpm check:declaration-rollups && pnpm check:api-snapshots && pnpm check:external-fixtures -- --skip-build",
    "gate:xlsx:list": "pnpm --filter @mog/xlsx-parser-wasm run gate:list",
    "gate:xlsx:schedule": "pnpm --filter @mog/xlsx-parser-wasm run gate:schedule",
    "gate:xlsx:plan:smoke": "pnpm --filter @mog/xlsx-parser-wasm run gate:plan:smoke",
    "gate:xlsx:plan:golden": "pnpm --filter @mog/xlsx-parser-wasm run gate:plan:golden",
    "gate:xlsx:plan:full": "pnpm --filter @mog/xlsx-parser-wasm run gate:plan:full",
    "gate:xlsx:check:smoke": "pnpm --filter @mog/xlsx-parser-wasm run gate:check:smoke",
    "gate:xlsx:check:golden": "pnpm --filter @mog/xlsx-parser-wasm run gate:check:golden",
    "gate:xlsx:check:full": "pnpm --filter @mog/xlsx-parser-wasm run gate:check:full"
  },
  "dependencies": {
    "@mog-sdk/node": "workspace:*",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mog": "workspace:*",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.0",
    "ws": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "react-icons": "5.5.0"
    }
  }
}
