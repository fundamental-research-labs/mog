{
  "name": "@mog-sdk/sdk",
  "version": "0.10.1",
  "description": "Headless spreadsheet engine with native Node and WASM runtime bindings",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "workerd": {
        "types": "./dist/workerd.d.ts",
        "default": "./dist/workerd.js"
      },
      "node-addons": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "node": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "browser": {
        "types": "./dist/wasm.d.ts",
        "default": "./dist/wasm.js"
      },
      "default": {
        "types": "./dist/wasm.d.ts",
        "default": "./dist/wasm.js"
      }
    },
    "./node": {
      "development": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./version-store": {
      "development": "./src/version-store.ts",
      "types": "./dist/version-store.d.ts",
      "import": "./dist/version-store.js",
      "require": "./dist/version-store.cjs",
      "default": "./dist/version-store.js"
    },
    "./wasm": {
      "development": "./src/wasm.ts",
      "types": "./dist/wasm.d.ts",
      "default": "./dist/wasm.js"
    },
    "./workerd": {
      "development": "./src/workerd.ts",
      "types": "./dist/workerd.d.ts",
      "default": "./dist/workerd.js"
    }
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "generate:api-spec": "tsx scripts/generate-api-spec.ts",
    "build": "tsx scripts/generate-api-spec.ts && tsup --no-dts && tsc -p tsconfig.build.json && node scripts/build-types.mjs && node ../../tools/fix-dts-extensions.mjs dist",
    "build:dev": "tsup --no-dts",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest --config jest.config.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "verify-build": "node scripts/verify-build.mjs",
    "smoke-test": "node scripts/smoke-test.mjs",
    "api-report": "api-extractor run --local --verbose",
    "api-report:ci": "api-extractor run --verbose",
    "verify-publish": "node ../../tools/verify-sdk-publish.mjs"
  },
  "keywords": [
    "spreadsheet",
    "excel",
    "headless",
    "formula",
    "xlsx",
    "compute",
    "data"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fundamental-research-labs/mog",
    "directory": "runtime/sdk"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "workerd": {
          "types": "./dist/workerd.d.ts",
          "default": "./dist/workerd.js"
        },
        "node-addons": {
          "types": "./dist/index.d.ts",
          "import": "./dist/index.js",
          "require": "./dist/index.cjs",
          "default": "./dist/index.js"
        },
        "node": {
          "types": "./dist/index.d.ts",
          "import": "./dist/index.js",
          "require": "./dist/index.cjs",
          "default": "./dist/index.js"
        },
        "browser": {
          "types": "./dist/wasm.d.ts",
          "default": "./dist/wasm.js"
        },
        "default": {
          "types": "./dist/wasm.d.ts",
          "default": "./dist/wasm.js"
        }
      },
      "./node": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./version-store": {
        "types": "./dist/version-store.d.ts",
        "import": "./dist/version-store.js",
        "require": "./dist/version-store.cjs",
        "default": "./dist/version-store.js"
      },
      "./wasm": {
        "types": "./dist/wasm.d.ts",
        "default": "./dist/wasm.js"
      },
      "./workerd": {
        "types": "./dist/workerd.d.ts",
        "default": "./dist/workerd.js"
      }
    }
  },
  "dependencies": {
    "@mog-sdk/contracts": "workspace:*",
    "@mog-sdk/wasm": "workspace:*",
    "@types/node": "^25.5.0"
  },
  "optionalDependencies": {
    "@mog-sdk/darwin-arm64": "workspace:*",
    "@mog-sdk/darwin-x64": "workspace:*",
    "@mog-sdk/linux-arm64-gnu": "workspace:*",
    "@mog-sdk/linux-arm64-musl": "workspace:*",
    "@mog-sdk/linux-x64-gnu": "workspace:*",
    "@mog-sdk/linux-x64-musl": "workspace:*",
    "@mog-sdk/win32-x64-msvc": "workspace:*"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@mog-sdk/chart-raster-wasm": "workspace:*",
    "@mog-sdk/kernel": "workspace:*",
    "@mog-sdk/types-host": "workspace:*",
    "@mog/kernel-host-internal": "workspace:*",
    "@mog/charts": "workspace:*",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
