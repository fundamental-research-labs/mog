{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "../kernel/src/global.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "references": [
    { "path": "../types/host" },
    { "path": "../contracts" },
    { "path": "../tools/devtools" },
    { "path": "../infra/env" },
    { "path": "../infra/icons" },
    { "path": "../infra/platform" },
    { "path": "../infra/transport" },
    { "path": "../kernel" },
    { "path": "../spreadsheet-utils" }
  ]
}
