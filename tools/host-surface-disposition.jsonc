    "@mog-sdk/kernel:DocumentFactory.createFromHostContext": {
      "disposition": "removed",
      "status": "verified",
      "verification": "kernel public root exports a DocumentFactory facade without createFromHostContext; internal monorepo path remains in kernel/src/api/document/document-factory.ts",
