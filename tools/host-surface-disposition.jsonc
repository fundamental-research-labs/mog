    },
    "@mog/kernel-host-internal:createHostBackedDocument": {
      "disposition": "authorized-materialization-api",
      "status": "complete",
      "verification": "pnpm --filter @mog-sdk/kernel test -- host-import-source public-source-handling host-integration host-no-globals-sentinel --runInBand",
      "artifact": "kernel/host-internal/src/create.ts",
    },
    "shell:standalone-browser-host-backed-import": {
      "disposition": "authorized-materialization-api",
      "status": "complete",
      "verification": "pnpm --filter @mog/shell test -- create-document-manager.test.ts",
      "artifact": "shell/src/host-adapters/standalone-browser-host.ts",
    },
    "runtime/src-tauri:tauri-desktop-host-adapter": {
      "disposition": "downstream-blocker",
      "status": "blocked",
      "blockedBy": "desktop native command authorization and tauri-file-provider materializer",
