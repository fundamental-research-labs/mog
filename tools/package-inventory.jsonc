{
  // Machine-readable package disposition inventory.
  // Single source of truth for every workspace package's boundary constraints.
  // Derived from the package disposition inventory.
  //
  // disposition: "ship-public" | "binary-wrapper" | "bundle-only" | "workspace-internal"
  //            | "private" | "dev-eval" | "generated-asset" | "reserved" | "monorepo-root"
  // requirePrivate: true if the package.json MUST have "private": true
  // publicTarget: the primary public package or marketplace target (null if not publishable)
  // marketplaceTargets: all marketplace targets for marketplace-extension packages
  // forbiddenRuntimeDeps: patterns that must NOT appear in dependencies/peerDependencies

  // ── monorepo root ─────────────────────────────────────────────────────
  "@mog/spreadsheet": {
    "disposition": "monorepo-root",
    "requirePrivate": true,
    "publicTarget": null,
    "forbiddenRuntimeDeps": [],
  },

  // ── ship-public ───────────────────────────────────────────────────────
  "@mog-sdk/sdk": {
    "disposition": "ship-public",
    "requirePrivate": false,
    "publicTarget": "@mog-sdk/sdk",
    "forbiddenRuntimeDeps": [
      "@mog-sdk/kernel",
      "@mog-sdk/spreadsheet-contracts",
      "@mog/types-*",
      "@mog/*",
    ],
    "exports": {
      "./node": { "disposition": "public-experimental" },
      "./version-store": { "disposition": "public-experimental" },
      "./wasm": { "disposition": "public-experimental" },
      "./workerd": { "disposition": "public-experimental" },
    },
  },
  "@mog-sdk/embed": {
    "disposition": "ship-public",
    "requirePrivate": false,
    "publicTarget": "@mog-sdk/embed",
    "forbiddenRuntimeDeps": ["@mog-sdk/spreadsheet-contracts", "@mog/types-*", "@mog/*"],
    "exports": {
      "./react": { "disposition": "public-experimental" },
      "./web-component": { "disposition": "public-experimental" },
      "./config": { "disposition": "public-experimental" },
      "./internal/views-host": {
        "disposition": "workspace-private-friend",
        "allowedProductionConsumers": [],
        "allowedDevConsumers": [],
        "allowedExternalDevConsumers": ["@mog/views-host"],
        "publicArtifact": "strip",
      },
    },
  },
  "@mog-sdk/kernel": {
    "disposition": "workspace-internal",
    "requirePrivate": true,
    "publicTarget": null,
    "forbiddenRuntimeDeps": [
      "@mog-sdk/spreadsheet-contracts",
      "@mog/types-*",
      "@mog/*",
      "@rust-bridge/*",
    ],
    "exports": {
      "./security": { "disposition": "public-experimental" },
      "./keyboard": { "disposition": "public-experimental" },
      "./storage": { "disposition": "public-experimental" },
      "./testing": { "disposition": "public-experimental" },
      "./api": { "disposition": "public-experimental" },
      "./app-api": {
        "disposition": "workspace-private-friend",
        "allowedProductionConsumers": ["@mog-sdk/spreadsheet-app", "@mog/shell"],
        "allowedDevConsumers": [],
        "allowedExternalDevConsumers": ["@mog/spreadsheet-dev"],
        "publicArtifact": "strip",
      },
      "./services/capabilities": { "disposition": "public-experimental" },
      "./contracts/api": { "disposition": "public-experimental" },
      "./host-lifecycle-internal": {
        "disposition": "workspace-private-friend",
        "allowedProductionConsumers": ["@mog/kernel-host-internal"],
        "publicArtifact": "strip",
      },
    },
  },
