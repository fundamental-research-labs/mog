// Baseline for tools/check-platform-dependencies.mjs.
// Entries are per matched occurrence. New direct platform dependency
// occurrences are enforced by stable file/rule/match counts so line
// movement does not create false positives.
{
  "$schema": "./platform-dependency-allowlist.schema.json",
  "description": "Occurrence-level baseline for direct platform dependency usage. Run `pnpm check:platform-dependencies -- --update` after deliberately reducing or reclassifying debt.",
  "rules": {
    "ts-date-now": {
      "category": "host-wall-time",
      "language": "ts",
    },
    "ts-performance-now": {
      "category": "elapsed-time",
      "language": "ts",
    },
    "ts-performance-mark-measure": {
      "category": "elapsed-time",
      "language": "ts",
    },
    "ts-math-random": {
      "category": "entropy-or-id-generation",
      "language": "ts",
    },
    "ts-crypto-random-uuid": {
      "category": "id-generation",
      "language": "ts",
    },
    "ts-crypto-get-random-values": {
      "category": "entropy",
      "language": "ts",
    },
    "ts-process-global": {
      "category": "runtime-detection",
      "language": "ts",
    },
    "ts-import-meta-env": {
      "category": "environment",
      "language": "ts",
    },
    "ts-runtime-global-detection": {
      "category": "runtime-detection",
      "language": "ts",
    },
    "ts-dynamic-import-meta": {
      "category": "environment",
      "language": "ts",
    },
    "rs-system-time-now": {
      "category": "rust-wall-time",
      "language": "rs",
    },
    "rs-instant-now": {
      "category": "elapsed-time",
      "language": "rs",
    },
    "rs-chrono-utc-now": {
      "category": "rust-wall-time",
      "language": "rs",
    },
    "rs-js-sys-date-now": {
      "category": "rust-wall-time",
      "language": "rs",
    },
    "rs-uuid-new-v4": {
      "category": "id-generation",
      "language": "rs",
    },
    "rs-randomness": {
      "category": "entropy",
      "language": "rs",
    },
    "rs-runtime-primitives-call": {
      "category": "runtime-primitive-usage",
      "language": "rs",
    },
    "rs-cfg-wasm32": {
      "category": "target-mechanics",
      "language": "rs",
    },
  },
