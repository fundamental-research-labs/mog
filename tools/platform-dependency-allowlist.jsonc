// Baseline for tools/check-platform-dependencies.mjs.
// Entries are grouped by stable file/rule/match counts. Exact
// line/column locations are generated by the scanner at runtime.
{
  "$schema": "./platform-dependency-allowlist.schema.json",
  "description": "Grouped count baseline for direct platform dependency usage. Run `pnpm check:platform-dependencies -- --update` after deliberately reducing or reclassifying debt.",
  "rules": {
    "ts-date-now": {
      "category": "host-wall-time",
      "language": "ts",
    },
    "ts-performance-now": {
      "category": "elapsed-time",
      "language": "ts",
    },
    "ts-performance-mark-measure": {
      "category": "elapsed-time",
      "language": "ts",
    },
    "ts-math-random": {
      "category": "entropy-or-id-generation",
      "language": "ts",
    },
    "ts-crypto-random-uuid": {
      "category": "id-generation",
      "language": "ts",
    },
    "ts-crypto-get-random-values": {
      "category": "entropy",
      "language": "ts",
    },
    "ts-process-global": {
      "category": "runtime-detection",
      "language": "ts",
    },
    "ts-import-meta-env": {
      "category": "environment",
      "language": "ts",
    },
    "ts-runtime-global-detection": {
      "category": "runtime-detection",
      "language": "ts",
    },
    "ts-dynamic-import-meta": {
      "category": "environment",
      "language": "ts",
    },
    "rs-system-time-now": {
      "category": "rust-wall-time",
      "language": "rs",
    },
    "rs-instant-now": {
      "category": "elapsed-time",
      "language": "rs",
    },
    "rs-chrono-utc-now": {
      "category": "rust-wall-time",
      "language": "rs",
    },
    "rs-js-sys-date-now": {
      "category": "rust-wall-time",
      "language": "rs",
    },
    "rs-uuid-new-v4": {
      "category": "id-generation",
      "language": "rs",
    },
    "rs-randomness": {
      "category": "entropy",
      "language": "rs",
    },
    "rs-runtime-primitives-call": {
      "category": "runtime-primitive-usage",
      "language": "rs",
    },
    "rs-cfg-wasm32": {
      "category": "target-mechanics",
      "language": "rs",
    },
  },
  "ownerDefaults": {
    "local-elapsed-budget-owner": {
      "reason": "Existing elapsed-time/profiling occurrence pending owner-specific clock migration.",
      "migrationPlan": "Route through a local monotonic clock owned by the scheduler, parser, solver, or UI runtime.",
    },
    "platform-contract-migration": {
      "reason": "Existing direct platform dependency captured by the platform dependency inventory.",
      "migrationPlan": "Replace with the semantic owner contract named by the platform facts matrix.",
    },
    "target-mechanics-owner": {
      "reason": "Existing target-specific mechanics occurrence pending review.",
      "migrationPlan": "Keep only at binding/local compatibility boundaries; remove from domain logic.",
    },
    "test-dev-only": {
      "reason": "Test or development-only platform dependency occurrence.",
      "migrationPlan": "Keep outside production contract or remove when the test no longer needs it.",
    },
  },
  "allowlist": [
    {
