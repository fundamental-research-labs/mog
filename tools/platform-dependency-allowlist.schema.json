{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["description", "rules", "ownerDefaults", "allowlist"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "language"],
        "properties": {
          "category": {
            "type": "string"
          },
          "language": {
            "enum": ["rs", "ts"]
          }
        }
      }
    },
    "ownerDefaults": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason", "migrationPlan"],
        "properties": {
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "migrationPlan": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "allowlist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "ruleId",
          "category",
          "match",
          "allowedCount",
          "owner"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "ruleId": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "match": {
            "type": "string",
            "minLength": 1
          },
          "allowedCount": {
            "type": "integer",
            "minimum": 0
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "migrationPlan": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
