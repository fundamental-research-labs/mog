{
  // Public source projection contract. This file is intentionally explicit:
  // public source is a generated tree, not a filtered long-lived fork.
  "schemaVersion": 1,
  "publicRepository": {
    "owner": "fundamental-research-labs",
    "name": "mog",
    "url": "https://github.com/fundamental-research-labs/mog",
  },
  "stagingRepository": {
    "owner": "fundamental-research-labs",
    "name": "mog-public-staging",
    "url": "https://github.com/fundamental-research-labs/mog-public-staging",
  },
  "toolchain": {
    "node": "24.6.0",
    "pnpm": "10.11.0",
    "rust": "1.93.0",
    "cargo": "1.93.0",
  },
  "packageManager": "pnpm@10.11.0",
  "publicCommitIdentity": {
    "name": "gyyang",
    "email": "gyyang@users.noreply.github.com",
  },
  "includePaths": [
    ".cargo/",
    ".eslintrc.cjs",
    ".gitignore",
    ".prettierignore",
    ".prettierrc",
    "Cargo.toml",
    "CONTRIBUTING.md",
