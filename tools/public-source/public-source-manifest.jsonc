    "package.json",
    "runtime/embed/",
    "runtime/sdk/",
    "runtime/spreadsheet-app/",
    "shell/",
    "spreadsheet-utils/",
    "table-engine/",
    "tools/api-snapshots/",
    "tools/assemble-public-packages.mjs",
    "tools/binary-wrapper-surface-disposition.jsonc",
    "tools/build-public-artifacts.mjs",
    "tools/check-api-snapshots.mjs",
    "tools/check-binary-wrapper-surfaces.mjs",
    "tools/check-contract-identity.mjs",
    "tools/check-contract-runtime-imports.mjs",
    "tools/check-contracts-declaration-identity.mjs",
    "tools/check-contracts-runtime-inventory.mjs",
    "tools/check-declaration-rollups.mjs",
    "tools/check-host-surface-disposition.mjs",
    "tools/check-platform-dependencies.mjs",
    "tools/check-wasm-boundary.sh",
    "tools/contracts-runtime-inventory.json",
    "tools/eslint-plugin-mog/",
    "tools/find-missing-deps.mjs",
    "tools/fix-dts-extensions.mjs",
    "tools/generate-api-reference.ts",
    "tools/host-surface-disposition.jsonc",
    "tools/package-export-dispositions.mjs",
    "tools/lint-dist.sh",
    "tools/package-inventory.jsonc",
    "tools/platform-dependency-allowlist.jsonc",
    "tools/platform-dependency-allowlist.schema.json",
    "tools/public-package-manifest.mjs",
    "tools/public-source/",
    "tools/release-readiness-scanner.mjs",
    "tools/verify-sdk-publish.mjs",
    "tools/validate-packages.mjs",
    "tsconfig.json",
    "types/",
    "typeset/math-engine/",
    "ui/",
    "views/sheet-view/",
  ],
  "excludePaths": [
    ".DS_Store",
    ".claude/",
    "**/.DS_Store",
    "**/.next",
    "**/.next/**",
    "**/.tsup",
    "**/.tsup/",
    "**/.tsup/**",
    "**/coverage",
    "**/coverage/**",
    "**/dist",
    "**/dist/**",
    "**/node_modules",
    "**/node_modules/**",
    "**/target",
    "**/target/**",
    "**/target-native",
    "**/target-native/**",
    "**/target-wasm",
    "**/target-wasm/**",
    "**/.venv",
    "**/.venv/**",
    "**/*.map",
    "**/*.tsbuildinfo",
    "*.map",
    "*.tsbuildinfo",
    "AGENTS.md",
    "Dockerfile.headless",
    "apps/task-tracker/",
    "canvas/lab/",
    "compute/core/**/fuzz/",
    "compute/core/fuzz/",
    "compute/napi/*.node",
    "compute/napi/**/*.node",
    "compute/pyo3/python/mog/_native.abi3.so",
    "compute/wasm/npm/*.wasm",
    "compute/wasm/pkg/",
    "dev/",
    "examples/",
    "file-io/xlsx/parser/fuzz/",
    "file-io/ooxml/spec/",
    "infra/rust-bridge/examples/",
    "infra/rust-bridge/bridge-cli/",
    "node_modules/",
    "output/",
    "plans/",
    "render.yaml",
    "runtime/server/",
    "runtime/src-tauri/",
    "runtime/test-host/",
    "target/",
    "target-native/",
    "target-wasm/",
    "tsconfig.tsbuildinfo",
    "typeset/lab/",
    "views/sheet-widgets/",
  ],
  "generatedFiles": [
    ".github/workflows/public-ci.yml",
    "Cargo.lock",
    "Cargo.toml",
    "THIRD_PARTY_NOTICES.md",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tools/package-inventory.jsonc",
    "tsconfig.json",
  ],
  "publicWorkspacePackages": [
    ".",
    "apps/spreadsheet",
    "canvas/drawing-canvas",
    "canvas/drawing/engine",
    "canvas/drawing/geometry",
    "canvas/drawing/ink",
    "canvas/drawing/shapes",
    "canvas/drawing/diagram",
    "canvas/drawing/text-effects",
    "canvas/engine",
    "canvas/grid-canvas",
    "canvas/grid-renderer",
    "canvas/overlay",
    "canvas/spatial",
    "charts",
    "compute/napi",
    "compute/napi/npm/darwin-arm64",
    "compute/napi/npm/darwin-x64",
    "compute/napi/npm/linux-arm64-gnu",
    "compute/napi/npm/linux-arm64-musl",
    "compute/napi/npm/linux-x64-gnu",
    "compute/napi/npm/linux-x64-musl",
    "compute/napi/npm/win32-x64-msvc",
    "compute/wasm/npm",
    "contracts",
    "contracts/runtime-services",
    "file-io/pdf/graphics",
    "file-io/pdf/layout",
    "file-io/print-export",
    "file-io/xlsx/bridge",
    "file-io/xlsx/parser",
    "file-io/xlsx/tooling",
    "infra/culture",
    "infra/devtools-public",
    "infra/env",
    "infra/icons",
    "infra/platform",
    "infra/platform/memory",
    "infra/rust-bridge/bridge-ts",
    "infra/rust-bridge/client",
    "infra/spreadsheet-testing-public",
    "infra/transport",
    "kernel",
    "kernel/host-internal",
    "runtime/embed",
    "runtime/sdk",
    "runtime/spreadsheet-app",
    "shell",
    "spreadsheet-utils",
    "table-engine",
    "tools/eslint-plugin-mog",
    "types/api",
    "types/app-platform",
    "types/bridges",
    "types/commands",
    "types/connections",
    "types/core",
    "types/culture",
    "types/data",
    "types/document",
    "types/editor",
    "types/events",
    "types/formatting",
    "types/host",
    "types/machines",
    "types/objects",
    "types/rendering",
    "types/viewport",
    "typeset/math-engine",
    "ui",
    "views/sheet-view",
  ],
  "allowedPackageJsonGlobs": ["fixtures/external/**/package.json"],
  "publicCargoMembers": [
    "domain-types",
    "compute/core",
    "compute/core/crates/types/value-types",
    "compute/core/crates/types/cell-types",
    "compute/core/crates/types/workbook-types",
    "compute/core/crates/types/formula-types",
    "compute/core/crates/types/finite-at-boundary",
    "compute/core/crates/types/finite-at-boundary-walker",
    "compute/core/crates/compute-parser",
    "compute/core/crates/compute-stats",
    "compute/core/crates/compute-pivot",
    "compute/core/crates/compute-relational",
    "compute/core/crates/types/pivot-types",
    "compute/core/crates/compute-table",
    "compute/core/crates/compute-functions",
    "compute/core/crates/compute-cf",
    "compute/core/crates/compute-formats",
    "compute/core/crates/compute-schema",
    "compute/core/crates/compute-graph",
    "compute/core/crates/types/snapshot-types",
    "compute/core/crates/compute-fill",
    "compute/core/crates/compute-charts",
    "compute/core/crates/compute-solver",
    "compute/core/crates/compute-collab",
    "compute/core/crates/compute-coordinator",
    "compute/core/crates/compute-document",
    "compute/core/crates/compute-wire",
    "compute/core/crates/compute-layout-index",
    "compute/core/crates/compute-text-measurement",
    "compute/core/crates/compute-screenshot",
    "compute/core/crates/compute-security",
    "compute/wasm",
    "compute/napi",
    "compute/pyo3",
    "compute/api",
    "file-io/xlsx/parser",
    "file-io/xlsx/parser/xml-derive",
    "file-io/xlsx-api",
    "file-io/csv-parser",
    "file-io/ooxml/types",
    "file-io/pdf/core",
    "infra/rust-bridge/bridge-describe",
    "infra/rust-bridge/bridge-types",
    "infra/rust-bridge/bridge-derive",
    "infra/rust-bridge/bridge-ir",
    "infra/rust-bridge/bridge-core",
    "infra/rust-bridge/bridge-wasm",
    "infra/rust-bridge/bridge-wasm/macros",
    "infra/rust-bridge/bridge-delegate",
    "infra/rust-bridge/bridge-delegate/macros",
    "infra/rust-bridge/bridge-tauri",
    "infra/rust-bridge/bridge-tauri/macros",
    "infra/rust-bridge/bridge-napi",
    "infra/rust-bridge/bridge-napi/macros",
    "infra/rust-bridge/bridge-pyo3",
    "infra/rust-bridge/bridge-pyo3/macros",
    "infra/rust-bridge/bridge-ts",
  ],
  "allowedStandaloneCargoTomlGlobs": ["infra/rust-bridge/bridge-tauri/tests/support/**/Cargo.toml"],
  "generatedWorkspacePackages": [
    {
      "path": "infra/devtools-public",
      "name": "@mog/devtools",
      "kind": "production-safe-devtools-facade",
    },
    {
      "path": "infra/spreadsheet-testing-public",
      "name": "@mog/spreadsheet-testing",
      "kind": "production-safe-spreadsheet-testing-facade",
    },
  ],
  "allowedBinaryArtifacts": [
    {
      "path": "kernel/src/bridges/wire/__tests__/fixtures/mutation.bin",
      "kind": "synthetic-test-fixture",
      "provenance": "Synthetic compute-wire mutation fixture used by public tests",
    },
    {
      "path": "kernel/src/bridges/wire/__tests__/fixtures/viewport.bin",
      "kind": "synthetic-test-fixture",
      "provenance": "Synthetic compute-wire viewport fixture used by public tests",
    },
    {
      "path": "infra/transport/test-fixtures/synthetic-trap/synthetic-trap.wasm",
      "kind": "synthetic-test-fixture",
      "provenance": "Documented in infra/transport/test-fixtures/synthetic-trap/README.md",
    },
  ],
  "allowedFindings": [
    {
      "category": "absolute-local-path",
      "path": "kernel/src/services/filesystem/paths.ts",
      "term": "/home/<user>/...",
    },
    {
      "category": "absolute-local-path",
      "path": "kernel/src/services/filesystem/paths.ts",
      "term": "/Users/<user>/...",
    },
    {
      "category": "absolute-local-path",
      "path": "kernel/src/services/filesystem/paths.ts",
      "term": "C:\\Users\\<user>\\...",
    },
    {
      "category": "absolute-local-path",
      "path": "tools/public-source/check-public-source-hygiene.mjs",
      "term": "/Volumes/...",
    },
    {
      "category": "absolute-local-path",
      "path": "tools/public-source/check-public-source-hygiene.mjs",
      "term": "/private/var/folders/...",
    },
    {
      "category": "absolute-local-path",
      "path": "tools/public-source/public-source-manifest.jsonc",
      "term": "/Volumes/...",
    },
    {
      "category": "absolute-local-path",
      "path": "tools/public-source/public-source-manifest.jsonc",
      "term": "/private/var/folders/...",
    },
  ],
  "privateTerms": [
    "fundamental-research-labs/mog-internal",
    "lyfegame/shortcut",
    "training-infra-2",
    "@fundamental-research-labs",
    "mog-internal",
  ],
  "forbiddenPathReferences": [".claude/", "agents/skills/", "dev/", "plans/"],
  "allowedPrivateTermGlobs": [
    "tools/public-source/public-source-manifest.jsonc",
    "tools/public-source/project-public-source.mjs",
  ],
  "repositoryMetadata": {
    "repository": {
      "type": "git",
      "url": "https://github.com/fundamental-research-labs/mog",
    },
    "license": "MIT",
  },
  "packageDependencyRemovals": {
    "devDependencies": ["@mog/test-host", "@mog/vite-wasm-plugin"],
  },
  "rootPackageScripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "node infra/icons/scripts/ensure-generated.mjs && tsc -b",
    "validate:public-source": "node tools/public-source/check-public-source-hygiene.mjs --root . --ignore-installed-dependencies && node tools/public-source/generate-public-inventory.mjs --root . --check",
    "build:public-artifacts": "node tools/build-public-artifacts.mjs",
    "assemble:public-packages": "node tools/assemble-public-packages.mjs",
    "check:declaration-rollups": "node tools/check-declaration-rollups.mjs",
    "check:api-snapshots": "node tools/check-api-snapshots.mjs",
    "check:binary-wrapper-surfaces": "node tools/check-binary-wrapper-surfaces.mjs",
    "check:external-fixtures": "node fixtures/external/orchestrate.mjs",
    "project:public-source": "node tools/public-source/project-public-source.mjs",
  },
  "verificationCommands": {
    "source": [
      "node tools/public-source/check-public-source-hygiene.mjs --root .",
      "node tools/public-source/generate-public-inventory.mjs --root . --check",
    ],
    "typescript": [
      "pnpm install --frozen-lockfile",
      "pnpm typecheck",
      "pnpm validate:public-source",
      "pnpm check:declaration-rollups",
      "pnpm check:api-snapshots",
    ],
    "rust": [
      "cargo check --workspace --locked",
      "cargo test --workspace --locked",
      "cargo clippy --workspace --locked",
    ],
    "artifacts": ["pnpm build:public-artifacts", "pnpm assemble:public-packages"],
  },
}
