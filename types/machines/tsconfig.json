{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "references": [
    { "path": "../commands" },
    { "path": "../core" },
    { "path": "../data" },
    { "path": "../document" },
    { "path": "../editor" },
    { "path": "../events" },
    { "path": "../objects" },
    { "path": "../viewport" }
  ]
}
