{
  "name": "@mog-sdk/sheet-view",
  "version": "0.9.6",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && api-extractor run --local --verbose && cp dist/.rollup/index.d.ts dist/index.d.ts && node -e \"const fs=require('node:fs');const p='dist/index.d.ts';const ref='/// <reference lib=\\\"esnext.disposable\\\" />\\n';const s=fs.readFileSync(p,'utf8');if(!s.startsWith(ref))fs.writeFileSync(p,ref+s);\" && node ../../tools/fix-dts-extensions.mjs dist && rm -rf dist/.rollup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@mog-sdk/contracts": "workspace:*"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@mog/canvas-engine": "workspace:*",
    "@mog/grid-canvas": "workspace:*",
    "@mog/grid-renderer": "workspace:*",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fundamental-research-labs/mog",
    "directory": "views/sheet-view"
  },
  "publishConfig": {
    "access": "public"
  }
}
