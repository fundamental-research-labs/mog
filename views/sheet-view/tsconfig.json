{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./node_modules/.cache/tsc"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "references": [
    { "path": "../../canvas/engine" },
    { "path": "../../canvas/grid-canvas" },
    { "path": "../../canvas/grid-renderer" },
    { "path": "../../contracts" }
  ]
}
